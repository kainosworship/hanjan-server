# ==================================================
# HANJAN APP — 환경 변수 예시 (hanjan-app/.env)
# ==================================================
# 이 파일을 .env로 복사하고 실제 값으로 교체하세요.
# cp .env.example .env

# ---- API 서버 ----
# 로컬 개발: http://localhost:3000/api
# 프로덕션: https://api.hanjan.app/api
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# ---- WebSocket 서버 ----
# 로컬 개발: http://localhost:3000
# 프로덕션: https://api.hanjan.app
EXPO_PUBLIC_SOCKET_URL=http://localhost:3000

# ---- RevenueCat ----
# RevenueCat 대시보드 > 앱 설정 > API 키에서 확인
# https://app.revenuecat.com
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=appl_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=goog_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Kakao 지도 ----
# Kakao Developers > 내 애플리케이션 > 앱 키 > JavaScript 키
# https://developers.kakao.com
EXPO_PUBLIC_KAKAO_MAP_KEY=your_kakao_map_key

# ---- 앱 스킴 (딥링크) ----
EXPO_PUBLIC_APP_SCHEME=hanjan

# ---- 앱 웹 URL ----
EXPO_PUBLIC_WEB_URL=https://hanjan.app

# ---- Mixpanel (분석, 선택) ----
# https://mixpanel.com
EXPO_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token

# ---- Sentry (오류 추적, 선택) ----
# https://sentry.io
EXPO_PUBLIC_SENTRY_DSN=https://xxxxxxxx@o0.ingest.sentry.io/0

# ---- 앱 환경 ----
# development | preview | production
APP_ENV=development
