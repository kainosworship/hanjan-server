{
  "expo": {
    "name": "한잔",
    "slug": "hanjan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "scheme": "hanjan",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F5"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hanjan.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "한잔은 신분증 촬영 및 실시간 셀피 인증을 위해 카메라가 필요합니다.",
        "NSLocationWhenInUseUsageDescription": "주변 사람들과 실시간 매칭을 위해 위치 정보가 필요합니다.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "안심 만남 위치 공유를 위해 위치 정보가 필요합니다.",
        "NSMicrophoneUsageDescription": "음성 메시지 전송을 위해 마이크가 필요합니다.",
        "NSPhotoLibraryUsageDescription": "프로필 사진 업로드를 위해 사진 라이브러리 접근이 필요합니다.",
        "NSFaceIDUsageDescription": "더 빠른 로그인을 위해 Face ID가 필요합니다."
      },
      "associatedDomains": [
        "applinks:hanjan.app"
      ]
    },
    "android": {
      "package": "com.hanjan.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/adaptive-icon.png",
        "backgroundColor": "#FF6B52"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "hanjan.app",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./src/assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "주변 사람들과 실시간 매칭 및 안심 만남 위치 공유를 위해 위치 정보가 필요합니다."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./src/assets/images/icon.png",
          "color": "#FF6B52",
          "sounds": []
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "한잔은 신분증 촬영 및 실시간 셀피 인증을 위해 카메라가 필요합니다."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "프로필 사진 업로드를 위해 사진 라이브러리 접근이 필요합니다.",
          "cameraPermission": "사진 촬영을 위해 카메라 접근이 필요합니다."
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./src/assets/fonts/Pretendard-Variable.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "blessnovas-organization",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "ec448137-5f5b-499a-b468-8afcfa75b3c4"
      }
    }
  }
}