# ==================================================
# HANJAN SERVER — 환경 변수 (.env)
# ==================================================
# cp .env.example .env 후 실제 값으로 교체

NODE_ENV=production
PORT=3000

# ---- PostgreSQL (Supabase 무료) ----
# https://supabase.com → New Project → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ---- Redis (Upstash 무료) ----
# https://upstash.com → Create Database → REST → REDIS_URL 복사
REDIS_URL=rediss://:[PASSWORD]@[HOST].upstash.io:6379

# ---- JWT (임의 문자열, 최소 32자) ----
JWT_SECRET=change_this_to_random_32_char_string
JWT_REFRESH_SECRET=change_this_to_another_random_string
JWT_EXPIRES_SECONDS=900
JWT_REFRESH_EXPIRES_DAYS=7

# ---- Firebase FCM (무료) ----
# https://console.firebase.google.com → 프로젝트 설정 → 서비스 계정 → 새 비공개 키 생성
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# ---- SMS OTP (개발/테스트: 콘솔 출력으로 대체, 실 서비스 시 아래 설정) ----
# https://coolsms.co.kr (1만원 무료 크레딧)
SMS_API_KEY=
SMS_SENDER=

# ---- RevenueCat (월 $2,500 매출까지 무료) ----
# https://app.revenuecat.com
REVENUECAT_WEBHOOK_SECRET=your_webhook_secret
REVENUECAT_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- CORS ----
CORS_ORIGINS=https://your-app-domain.com

# ---- 앱 URL (Railway 배포 후 URL로 변경) ----
APP_URL=https://your-app.up.railway.app
API_URL=https://your-app.up.railway.app
